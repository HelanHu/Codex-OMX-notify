{
  "notifications": {
    "enabled": true,
    "verbosity": "session",
    "idleCooldownSeconds": 60,
    "reply": {
      "enabled": false
    },
    "custom_cli_command": {
      "enabled": true,
      "command": "OMX_WINDOWS_NOTIFY_SOURCE=OMX bash ~/.codex/bin/windows-notify.sh {{event}} {{instruction}} {{sessionId}} {{projectPath}}",
      "timeout": 15000,
      "instruction": "Task Complete",
      "events": [
        "session-end",
        "stop"
      ]
    }
  }
}
